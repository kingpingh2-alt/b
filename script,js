document.getElementById("btn").addEventListener("click", function () {

  let km = parseFloat(document.getElementById("km").value);
  let petrol = parseFloat(document.getElementById("petrol").value);
  let electric = parseFloat(document.getElementById("electric").value);
  let mileage = parseFloat(document.getElementById("mileage").value);

  if (isNaN(km) || isNaN(petrol) || isNaN(electric) || isNaN(mileage)) {
    alert("Bhai sab input fill kar 😤");
    return;
  }

  // Petrol cost
  let petrolDaily = (km / mileage) * petrol;

  // EV cost (avg 1 unit = 6 km)
  let evDaily = (km / 6) * electric;

  let petrolMonthly = petrolDaily * 30;
  let evMonthly = evDaily * 30;

  let savings = petrolMonthly - evMonthly;

  document.getElementById("output").innerHTML = `
    <p>⛽ Petrol Monthly: ₹${petrolMonthly.toFixed(2)}</p>
    <p>⚡ EV Monthly: ₹${evMonthly.toFixed(2)}</p>
    <h2 style="color:#00ff88">💰 Savings: ₹${savings.toFixed(2)}</h2>
  `;
});
